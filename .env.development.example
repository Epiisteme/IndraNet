QBAS_ENVIRONMENT=development
QBAS_DATABASE_URL=sqlite:///./runtime/qbas.sqlite3
QBAS_AUTO_CREATE_SCHEMA=true
QBAS_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

QBAS_QUANTUM_DEVICE=default.qubit
QBAS_N_QUBITS=8
QBAS_QRNG_QUBITS=16
QBAS_AUTH_THRESHOLD=0.82

QBAS_SECRET_KEY=change-me-in-production
QBAS_API_KEY=dev-api-key
QBAS_REQUIRE_API_KEY=false
QBAS_REQUIRE_AUTH=false
QBAS_ENABLE_DEMO_TOKEN_ISSUER=true

QBAS_CKKS_ENABLED=true

VITE_QBAS_ENVIRONMENT=development
VITE_API_URL=/api/v1
VITE_QBAS_API_KEY=dev-api-key
VITE_QBAS_ENABLE_DEMO_API_KEY=true
VITE_QBAS_ENABLE_DEMO_TOKEN_ISSUER=true
